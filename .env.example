# Required in Vercel. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=replace-with-a-long-random-secret
NEXT_PUBLIC_SITE_URL=https://your-vercel-domain.vercel.app

# Local default. For persistent production admin/content edits, use a hosted Postgres URL instead.
DATABASE_URL=file:./infe-talent.sqlite
CONTACT_FORM_RECIPIENT=info@infetalent.com
CAREER_FORM_RECIPIENT=hr@infetalent.com
